<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> mini whatapp</title>
    <link rel="stylesheet" href="style.css"/>
</head>
<body>
    <h3>ALL Chats!</h3>
    <form method="GET" action="/chats/new">
        <button>new chat</button>
        
    </form>
<br/>
   <% for (let chat of chats) { %>

    <div class ="chat">
        <p>From : <i><%= chat.from %> </i> </p>

        <div class="msg">
        <p> <%= chat.msg %> </p>
        <form method="GET"action="/chats/<%=chat._id %>/edit">
            <button>edit</button>
        </form>
             <br/>
         <form method="POST"action="/chats/<%=chat._id %>?_method=DELETE">
            <button>delete</button>
        </form>
        </div>
        <p><i> Received by<%= chat.to %> </i> </p>
    <hr/>
    <p><%= chat.created_at.toString().split(" ")[4] %></p>
    <p><%= chat.created_at.toString().split(" ") .slice(0,4).join(" _")%></p>

    </div>
    <br></br><br></br>
<%}%>
</body>
</html>
